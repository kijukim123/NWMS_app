<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <EditText
        android:id="@+id/et_login_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="200dp"
        android:layout_marginEnd="8dp"
        android:ems="10"
        android:hint="아이디"
        android:inputType="textPersonName"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
    </EditText>

    <EditText
        android:id="@+id/et_login_pass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="32dp"
        android:layout_marginEnd="8dp"
        android:ems="10"
        android:hint="비밀번호"
        android:inputType="textPersonName"
        app:layout_constraintEnd_toEndOf="@+id/et_login_id"
        app:layout_constraintStart_toStartOf="@+id/et_login_id"
        app:layout_constraintTop_toBottomOf="@+id/et_login_id">
    </EditText>

    <Button
        android:id="@+id/btn_login1"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="32dp"
        android:text="로그인"
        android:background="@color/NsoftBlue"
        app:layout_constraintEnd_toEndOf="@+id/et_login_pass"
        app:layout_constraintStart_toStartOf="@+id/et_login_pass"
        app:layout_constraintTop_toBottomOf="@+id/et_login_pass">
    </Button>

    <Button
        android:id="@+id/btn_login2"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:layout_marginTop="32dp"
        android:text="회원가입"
        android:background="@color/NsoftBlue"
        app:layout_constraintEnd_toEndOf="@id/btn_login1"
        app:layout_constraintStart_toStartOf="@id/btn_login1"
        app:layout_constraintTop_toBottomOf="@id/btn_login1">
    </Button>

</androidx.constraintlayout.widget.ConstraintLayout>